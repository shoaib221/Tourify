```gitignore
# ========================================
# Backend (Django)
# ========================================

# Virtual environments
backend/venv/
backend/.venv/
backend/env/
backend/ENV/

# Python cache
backend/**/__pycache__/
backend/**/*.py[cod]

# Environment variables
backend/.env
backend/.env.*

# SQLite (if used)
backend/db.sqlite3
backend/*.sqlite3

# Static & media
backend/staticfiles/
backend/media/

# Python build files
backend/build/
backend/dist/
backend/*.egg-info/
backend/.pytest_cache/
backend/.mypy_cache/
backend/htmlcov/
backend/.coverage*

# Logs
backend/*.log

# ========================================
# Frontend (React + Vite)
# ========================================

frontend/node_modules/
frontend/dist/
frontend/.vite/

# Environment variables
frontend/.env
frontend/.env.*

# Logs
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*

# ========================================
# VS Code / IDEs
# ========================================

.vscode/
.idea/

# ========================================
# OS files
# ========================================

.DS_Store
Thumbs.db
Desktop.ini
```
